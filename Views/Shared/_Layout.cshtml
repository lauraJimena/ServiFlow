<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ServiFlow</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/ServiFlow.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/kanban.css" asp-append-version="true" />
</head>
<body class="layout-shell">
    <header class="sf-header">
        <div class="sf-navbar">
            <a class="sf-brand" asp-controller="Home" asp-action="Index">ServiFlow</a>

            <nav class="sf-menu">
                <a class="sf-link" asp-controller="Home" asp-action="Index">Servicios</a>

                
                 <a class="sf-link" asp-controller="Citas" asp-action="Index">Reservas</a> 

                
                
            </nav>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ServiFlow - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/kanban.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
