@{
    ViewData["Title"] = "Inicio";
}
<link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
<div class="container-fluid p-0">
    <div id="carouselExample" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="~/images/carrusel/img1.jpg" class="d-block w-100">
                <div class="carousel-overlay"></div> <!-- 🔥 overlay -->

            <div class="carousel-caption">
                <h2>Gestiona tus citas fácilmente</h2>
                <a class="btn btn-primary" asp-controller="Usuarios" asp-action="Login">Iniciar sesión</a>
                <a class="btn btn-success" asp-controller="Usuarios" asp-action="Registro">Registrarse</a>
            </div>
        </div>

        <div class="carousel-item">
            <img src="~/images/carrusel/img2.jpg" class="d-block w-100">
                <div class="carousel-overlay"></div> <!-- 🔥 overlay -->
            <div class="carousel-caption">
                <h2>Organiza tu negocio de belleza</h2>
            </div>
        </div>

       <div class="carousel-item">
           <img src="~/images/carrusel/img3.jpg" class="d-block w-100">
                <div class="carousel-overlay"></div> <!-- 🔥 overlay -->
           <div class="carousel-caption">
               <h2>Conecta con más clientes</h2>
           </div>
       </div>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>
</div>

<div class="container mt-5 text-center info-section fondo-tarjetas">
    <h2>¿Qué es ServiFlow?</h2>
    <p>Plataforma para gestionar citas de servicios de belleza de forma fácil y rápida.</p>
</div>

<div class="container mt-5">
    <div class="row justify-content-center g-4 cards-section">
        <div class="col-md-6 d-flex justify-content-center">
            <div class="info-card card-left">
                <h3>Cliente</h3>
                <p>Reserva citas, consulta disponibilidad y organiza tus servicios.</p>
            </div>
        </div>

        <div class="col-md-6 d-flex justify-content-center">
            <div class="info-card card-right">
                <h3>Emprendedor</h3>
                <p>Administra tu agenda, clientes y servicios en un solo lugar.</p>
            </div>
        </div>
    </div>
</div>
<div class="container mt-5 text-center fondo-tarjetas">
    <h2>Empieza ahora</h2>
    <a class="btn btn-primary m-2" asp-controller="Usuarios" asp-action="Login">Iniciar sesión</a>
    <a class="btn btn-success m-2" asp-controller="Usuarios" asp-action="Registro">Crear cuenta</a>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const cards = document.querySelectorAll(".info-card");

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("show");
                    observer.unobserve(entry.target);
                }
            });
        }, {
            threshold: 0.25
        });

        cards.forEach(card => observer.observe(card));
    });
</script>